def cmap_to_ramp(ramp_name, cmap_name, stops, alphas, norm=None):
    import matplotlib as mpl
    try:
        alphas = float(alphas)
        alphas = [alphas] * len(stops)
    except:
        pass

    if norm is None:
        vmin,vmax = np.min(stops),np.max(stops)
        norm = mpl.colors.Normalize(vmin, vmax)

    cmap = mpl.cm.ScalarMappable(norm, cmap_name)
    ramp_str = ""
    for stop,alpha in zip(stops, alphas):
        r,g,b,a = cmap.to_rgba(stop)
        hex = mpl.colors.to_hex([r, g, b])
        hex = f'0x{hex[1:]}'
        ramp_str += f'{stop} {hex} {alpha} '

    print(ramp_str)
    cmd.volume_ramp_new(ramp_name, ramp_str)

def single_contour_ramp(name : str, color : str, sigma : float, width : float, alpha : float):
    cmd.volume_ramp_new(
        name,
        f'{sigma - width} {color} 0.0 {sigma} {color} {alpha} {sigma + width} {color} 0.0',
    )

def set_anom_sigma(sigma=5., width=2.0, alpha=volume_alpha):
    sigma,width,alpha = map(float, (sigma, width, alpha))
    single_contour_ramp('anomramp', 'cb_orange', sigma, width, alpha)

def set_difference_sigma(sigma=3.5, width=0.5, alpha=volume_alpha):
    sigma,width,alpha = map(float, (sigma, width, alpha))
    single_contour_ramp('difference_plus', 'cb_green', sigma, width, alpha)
    single_contour_ramp('difference_minus', 'cb_purple', -sigma, width, alpha)


