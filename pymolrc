#MTZ Parsing helpers here
def gemmi_load_mtz(mtz_file, object_name, fkey, pkey):
    import gemmi
    print(f"loading map coefficients {fkey}, {pkey} from {mtz_file} into {object_name}")
    with tempfile.NamedTemporaryFile(suffix='.map') as map_file:
        subprocess.check_call(f'gemmi sf2map -f {fkey} -p {pkey} {mtz_file} {map_file.name}'.split())
        cmd.load(map_file.name, object_name)

def load_pdb(pdb_file, name=None):
    if name is None:
        name = pdb_file.removesuffix('.pdb')
    cmd.load(pdb_file)
    cmd.set('stick_radius', 0.2)
    cmd.set('valence', 'false')
    cmd.color('grey80', 'All')
    cmd.color('black', 'organic and name c*')
    cmd.util.cnc()
    cmd.hide('everything', 'polymer or solvent or metals or organic')
    cmd.show('sticks')
    cmd.set('sphere_scale', 0.2)
    cmd.show('spheres', 'sol or metals')

def load_phenix_mtz(mtz_file, selection=None, carve=None):
    gemmi_load_mtz(mtz_file, '2fofc_map', '2FOFCWT', 'PH2FOFCWT')
    gemmi_load_mtz(mtz_file, 'fofc_map', 'FOFCWT', 'PHFOFCWT')
    mtz = gemmi.read_mtz_file(mtz_file)
    columns = mtz.column_labels()
    cmd.volume('2fofc', '2fofc_map', ramp='electron_density', selection=selection, carve=carve)
    cmd.show('volume', '2fofc')
    cmd.volume('fofc_p', 'fofc_map', ramp='difference_plus', selection=selection, carve=carve)
    cmd.show('volume', 'fofc_p')
    cmd.volume('fofc_m', 'fofc_map', ramp='difference_minus', selection=selection, carve=carve)
    cmd.show('volume', 'fofc_m')
    if 'ANOM' in columns:
        phase_key = 'PANOM' #default for new phenix
        if 'PHANOM' in columns:
            phase_key = 'PHANOM' 
        gemmi_load_mtz(mtz_file, 'anom_map', 'ANOM', phase_key)
        cmd.volume('anom', 'anom_map', ramp='anomramp', selection=selection, carve=carve)
        cmd.show('volume', 'anom')

def load_phenix(mtz_file, pdb_file, carve=None):
    name = pdb_file.removesuffix('.pdb')
    load_pdb(pdb_file, name)
    load_phenix_mtz(mtz_file, selection=name, carve=carve)

